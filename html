<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EcoTech | Inovação Sustentável</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header>
        <nav aria-label="Menu Principal">
            <div class="logo">EcoTech</div>
            <div class="a11y-controls">
                <button id="contrast-toggle" aria-label="Alternar alto contraste">🌓</button>
                <button onclick="changeFontSize(1)" aria-label="Aumentar fonte">A+</button>
                <button onclick="changeFontSize(-1)" aria-label="Diminuir fonte">A-</button>
            </div>
        </nav>
    </header>

    <main>
        <section class="hero" aria-labelledby="hero-title">
            <div class="container reveal">
                <h1 id="hero-title">Tecnologia que respira com o planeta.</h1>
                <p>Soluções inteligentes para um futuro carbono zero.</p>
                <a href="#services" class="btn-primary">Conheça Nossas Soluções</a>
            </div>
        </section>

        <section id="services" class="services" aria-labelledby="services-title">
            <h2 id="services-title" class="reveal">Nossos Serviços</h2>
            <div id="services-grid" class="grid-container">
                </div>
        </section>

        <section class="carousel-section reveal" aria-label="Destaques">
            <h2>Projetos em Destaque</h2>
            <div class="carousel-container">
                <button class="prev" aria-label="Slide anterior">❮</button>
                <div id="carousel-track" class="carousel-track">
                    </div>
                <button class="next" aria-label="Próximo slide">❯</button>
            </div>
        </section>

        <section class="faq reveal" aria-labelledby="faq-title">
            <h2 id="faq-title">Perguntas Frequentes</h2>
            <div id="accordion-container">
                </div>
        </section>
    </main>

    <footer>
        <p>&copy; 2024 EcoTech Solutions. Desenvolvido com foco em acessibilidade.</p>
    </footer>

    <script src="script.js"></script>
</body>
</html>
